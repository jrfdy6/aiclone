<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.neo.weekly_memory_hygiene</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/neo/.openclaw/workspace/.venv-main-safe/bin/python</string>
      <string>/Users/neo/.openclaw/workspace/scripts/weekly_memory_hygiene.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/neo/.openclaw/workspace</string>

    <key>RunAtLoad</key>
    <true/>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Weekday</key>
      <integer>2</integer>
      <key>Hour</key>
      <integer>7</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/neo/.openclaw/logs/weekly_memory_hygiene.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/neo/.openclaw/logs/weekly_memory_hygiene.log</string>
  </dict>
</plist>
