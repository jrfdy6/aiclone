# Backend environment configuration
# Copy this file to .env and fill in the values.

# Firebase service account (stringified JSON)
# FIREBASE_SERVICE_ACCOUNT="{...}"

# OR provide a path to the service account file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json

# Google Drive service account credentials
# Option A: inline JSON
# GOOGLE_DRIVE_SERVICE_ACCOUNT="{...}"
# Option B: file path (recommended)
# GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=/Users/yourname/Desktop/Cursor/aiclone/keys/aiclone-drive-key.json

# Shared inbox Gmail API integration
# Production-friendly option: inject both JSON payloads directly as env vars
# GOOGLE_GMAIL_ACCOUNT_EMAIL=neo512235@gmail.com
# GOOGLE_GMAIL_OAUTH_CLIENT_JSON="{...}"
# GOOGLE_GMAIL_OAUTH_TOKEN_JSON="{...}"
# GOOGLE_GMAIL_SYNC_QUERY="in:inbox"
# GOOGLE_GMAIL_SYNC_MAX_RESULTS=50

# Local-host option: point to files created by scripts/connect_gmail_inbox.py
# GOOGLE_GMAIL_OAUTH_CLIENT_FILE=/Users/yourname/.openclaw/secrets/gmail_oauth_client.json
# GOOGLE_GMAIL_OAUTH_TOKEN_FILE=/Users/yourname/.openclaw/secrets/gmail_oauth_token.json
